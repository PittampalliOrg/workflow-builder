# Keep only the files needed by the root workflow-builder image build.
!package.json
!pnpm-lock.yaml
!.npmrc
!components.json
!drizzle.config.ts
!server-prod.js
!svelte.config.js
!tsconfig.json
!vite.config.ts
!drizzle/**
!lib/**
!scripts/
!scripts/build-db-scripts.mjs
!scripts/db-migrate-runtime.mjs
!scripts/seed-dev-user.ts
!scripts/seed-swebench-fixtures.ts
!scripts/seed-workflows.ts
!scripts/queue-swebench-environment-validation.ts
!scripts/sync-swebench-environment-builds.ts
!scripts/start-swebench-benchmark-run.ts
!scripts/backfill-agent-application-state.ts
!scripts/cutover-mlflow-application-lineage.ts
!scripts/sync-oauth-apps.ts
!scripts/esbuild-stubs/**
!scripts/fixtures/**
!src/**
!static/**

# Function-router is built from the repo root because its Dockerfile copies
# services/function-router paths. Same for workflow-orchestrator (Skaffold dev).
!services/
!services/function-router/**
!services/workflow-orchestrator/**

# Exclude python venv + caches from services/ (devspace leftovers; bloats
# Skaffold build context to >100MB if included)
**/node_modules/
**/.venv/
**/__pycache__/
**/.pytest_cache/
**/*.pyc
