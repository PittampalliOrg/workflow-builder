# Node.js toolchain stage — coding tasks (e.g. npm-based repos) need node/npm.
# Mirrors Dockerfile.sandbox-testing so dapr agents can run `npm test` etc.
FROM node:22-bookworm-slim AS node-bin

FROM ghcr.io/astral-sh/uv:python3.12-trixie-slim AS python-deps

WORKDIR /app
COPY pyproject.toml uv.lock* ./
RUN uv sync --frozen --no-dev
COPY openshell_proto_0_0_45/ ./openshell_proto_0_0_45/
RUN /app/.venv/bin/python - <<'PY'
from pathlib import Path
import shutil
import sysconfig

source = Path("/app/openshell_proto_0_0_45")
target = Path(sysconfig.get_paths()["purelib"]) / "openshell" / "_proto"
for path in source.iterdir():
    if path.name != "README.md":
        shutil.copy2(path, target / path.name)
PY

FROM python:3.12-slim-trixie

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        ripgrep \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /sandbox /mnt/session/outputs

# Node.js + npm/npx on PATH (/usr/local/bin) so coding agents can build/test
# npm-based repos directly instead of failing "node: command not found".
COPY --from=node-bin /usr/local/bin/node /usr/local/bin/
COPY --from=node-bin /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -sf ../lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -sf ../lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx \
    && node --version && npm --version

WORKDIR /app
COPY --from=python-deps /app/.venv /app/.venv
COPY src/ src/

ENV AGENT_SANDBOX_MODE=hybrid \
    AGENT_LOCAL_SANDBOX_ROOT=/sandbox \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    VIRTUAL_ENV=/app/.venv \
    PATH="/app/.venv/bin:/usr/local/bin:/usr/bin:/bin"

EXPOSE 8002
ENTRYPOINT []
CMD ["sh", "-lc", "exec /app/.venv/bin/uvicorn ${DAPR_AGENT_APP_MODULE:-src.main:app} --host 0.0.0.0 --port 8002"]
