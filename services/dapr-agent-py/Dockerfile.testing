FROM ghcr.io/astral-sh/uv:0.9.17 AS uv-bin

FROM node:22-bookworm-slim AS node-bin

FROM mcr.microsoft.com/playwright/python:v1.57.0-noble

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git \
    && rm -rf /var/lib/apt/lists/*

COPY --from=uv-bin /uv /uvx /usr/local/bin/
COPY --from=node-bin /usr/local/bin/node /usr/local/bin/
COPY --from=node-bin /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -sf ../lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -sf ../lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx

RUN npm install -g \
    @anthropic-ai/claude-code@latest \
    @playwright/mcp@latest \
    chrome-devtools-mcp@latest

WORKDIR /app
COPY pyproject.toml uv.lock* ./
RUN uv sync --frozen --no-dev
COPY openshell_proto_0_0_45/ ./openshell_proto_0_0_45/
RUN /app/.venv/bin/python - <<'PY'
from pathlib import Path
import shutil
import sysconfig

source = Path("/app/openshell_proto_0_0_45")
target = Path(sysconfig.get_paths()["purelib"]) / "openshell" / "_proto"
for path in source.iterdir():
    if path.name != "README.md":
        shutil.copy2(path, target / path.name)
PY
COPY src/ src/

EXPOSE 8002
CMD ["uv", "run", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8002"]
