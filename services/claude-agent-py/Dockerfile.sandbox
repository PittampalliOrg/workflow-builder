ARG OPENSHELL_SANDBOX_IMAGE=ghcr.io/pittampalliorg/openshell-sandbox:git-c390487a6bbcdd1a69cc6d7eb331a4aadaa9692c
ARG CLAUDE_CODE_NPM_VERSION=latest

FROM ghcr.io/astral-sh/uv:0.9.17 AS uv-bin

FROM node:22-bookworm-slim AS node-bin

FROM ${OPENSHELL_SANDBOX_IMAGE}

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git ripgrep \
    && rm -rf /var/lib/apt/lists/*

COPY --from=uv-bin /uv /uvx /usr/local/bin/
COPY --from=node-bin /usr/local/bin/node /usr/local/bin/
COPY --from=node-bin /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -sf ../lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -sf ../lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx \
    && npm install -g --force "@anthropic-ai/claude-code@${CLAUDE_CODE_NPM_VERSION}" \
    && npm cache clean --force

WORKDIR /app
COPY pyproject.toml uv.lock ./
RUN uv sync --python /usr/bin/python3 --no-python-downloads --frozen --no-dev
COPY src/ src/

ENV AGENT_SANDBOX_MODE=hybrid \
    AGENT_LOCAL_SANDBOX_ROOT=/sandbox \
    CLAUDE_AGENT_PY_DEFAULT_MODEL=claude-opus-4-8 \
    CLAUDE_AGENT_PY_PERMISSION_MODE=bypassPermissions \
    CLAUDE_AGENT_SDK_CLIENT_APP=workflow-builder-claude-agent-py/0.1.0 \
    CLAUDE_AGENT_SDK_CLI_PATH=/usr/local/bin/claude \
    VIRTUAL_ENV=/app/.venv \
    PATH="/app/.venv/bin:/usr/local/bin:/usr/bin:/bin"

EXPOSE 8002
ENTRYPOINT []
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8002"]
