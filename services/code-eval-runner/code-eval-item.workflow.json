{
  "id": "code-eval-item",
  "name": "Coding eval item",
  "description": "Run a single coding-eval row: provision a Python sandbox, write the test file, let the agent solve, then run pytest and capture pass/fail. Used by HumanEval+, MBPP+, and BigCodeBench evaluation templates.",
  "visibility": "public",
  "specVersion": "1.0.0",
  "engineType": "dapr",
  "spec": {
    "document": {
      "dsl": "1.0.0",
      "namespace": "workflow-builder.evaluations",
      "name": "code-eval-item",
      "version": "1.0.0",
      "title": "Coding eval item",
      "summary": "Provision a Python sandbox, write the test file, let an agent solve the task, run pytest, and emit pass/fail."
    },
    "do": [
      {
        "workspace_profile": {
          "call": "workspace/profile",
          "with": {
            "name": "code-eval-${ .trigger.taskId // .trigger.evaluation.itemId }",
            "rootPath": "/sandbox",
            "sandboxTemplate": "code-eval",
            "ttlSeconds": 1800,
            "keepAfterRun": true,
            "managedBy": "workflow-builder:evaluations:code-eval",
            "commandTimeoutMs": 180000,
            "timeoutMs": 240000,
            "enabledTools": [
              "execute_command",
              "read_file",
              "write_file",
              "edit_file",
              "list_files",
              "mkdir",
              "file_stat"
            ],
            "sandboxPolicy": {
              "keepAfterRun": true,
              "mode": "per-run",
              "template": "code-eval",
              "ttlSeconds": 1800
            }
          }
        }
      },
      {
        "validate_runtime": {
          "call": "workspace/command",
          "with": {
            "workspaceRef": "${ .workspace_profile.workspaceRef }",
            "command": "${ .trigger.runtimeProbeCommand }",
            "timeoutMs": 60000
          },
          "output": {
            "as": {
              "exitCode": "${ .output.result.exitCode // .output.exitCode // 1 }",
              "stdout": "${ .output.result.stdout // .output.stdout // \"\" }",
              "stderr": "${ .output.result.stderr // .output.stderr // \"\" }",
              "raw": "${ .output }"
            }
          }
        }
      },
      {
        "write_test": {
          "call": "workspace/write_file",
          "with": {
            "workspaceRef": "${ .workspace_profile.workspaceRef }",
            "path": "/sandbox/test_solution.py",
            "content": "${ .trigger.evaluation.expectedOutput.testFileContent }",
            "timeoutMs": 60000
          }
        }
      },
      {
        "solve": {
          "call": "durable/run",
          "with": {
            "body": {
              "agentRef": "${ .trigger.agentRef }",
              "prompt": "${ .trigger.solvePrompt }",
              "overrides": {
                "cwd": "/sandbox",
                "maxTurns": 30,
                "timeoutMinutes": 8
              }
            },
            "mode": "execute_direct",
            "cwd": "/sandbox",
            "sandboxName": "${ .workspace_profile.sandboxName }",
            "workspaceRef": "${ .workspace_profile.workspaceRef }",
            "sandboxPolicy": {
              "keepAfterRun": true,
              "mode": "per-run",
              "template": "code-eval",
              "ttlSeconds": 1800
            }
          }
        }
      },
      {
        "restore_test": {
          "call": "workspace/write_file",
          "with": {
            "workspaceRef": "${ .workspace_profile.workspaceRef }",
            "path": "/sandbox/test_solution.py",
            "content": "${ .trigger.evaluation.expectedOutput.testFileContent }",
            "timeoutMs": 60000
          }
        }
      },
      {
        "run_tests": {
          "call": "workspace/command",
          "with": {
            "workspaceRef": "${ .workspace_profile.workspaceRef }",
            "command": "set -u; cd /sandbox; if [ -f solution.py ]; then missing=0; else echo 'MISSING_SOLUTION' >&2; : > solution.py; missing=1; fi; run_dir=/tmp/code_eval_run; [ \"${run_dir}\" = \"/tmp/code_eval_run\" ] || exit 3; rm -rf \"${run_dir}\"; mkdir -p \"${run_dir}\"; cp /sandbox/solution.py \"${run_dir}/solution.py\"; cp /sandbox/test_solution.py \"${run_dir}/test_solution.py\"; cd \"${run_dir}\"; if [ \"${missing}\" = \"1\" ]; then pytest_exit=2; else PYTEST_DISABLE_PLUGIN_AUTOLOAD=1 CODE_EVAL_SOLUTION_PATH=\"${run_dir}/solution.py\" /sandbox/.venv/bin/python -m pytest -q --tb=short --noconftest test_solution.py 2>&1; pytest_exit=$?; fi; echo \"__PYTEST_EXIT_CODE__=${pytest_exit}\"; exit ${pytest_exit}",
            "allowFailure": true,
            "timeoutMs": 180000
          },
          "output": {
            "as": {
              "exitCode": "${ .output.result.exitCode // .output.exitCode // 1 }",
              "stdout": "${ .output.result.stdout // .output.stdout // \"\" }",
              "stderr": "${ .output.result.stderr // .output.stderr // \"\" }",
              "raw": "${ .output }"
            }
          }
        }
      },
      {
        "read_solution": {
          "call": "workspace/read_file",
          "with": {
            "workspaceRef": "${ .workspace_profile.workspaceRef }",
            "path": "/sandbox/solution.py",
            "timeoutMs": 60000
          },
          "output": {
            "as": {
              "content": "${ .output.result.content // .output.content // .output.result.output // .output.output // \"\" }",
              "raw": "${ .output }"
            }
          }
        }
      },
      {
        "capture_metadata": {
          "call": "workspace/command",
          "with": {
            "workspaceRef": "${ .workspace_profile.workspaceRef }",
            "command": "set -eu; /sandbox/.venv/bin/python - <<'PY'\nimport hashlib, json, pathlib\n\ndef digest(path):\n    p = pathlib.Path(path)\n    if not p.is_file():\n        return {'exists': False, 'sha256': '', 'bytes': 0}\n    data = p.read_bytes()\n    return {'exists': True, 'sha256': hashlib.sha256(data).hexdigest(), 'bytes': len(data)}\n\nsolution = digest('/sandbox/solution.py')\ntest_file = digest('/sandbox/test_solution.py')\nprint(json.dumps({\n    'solutionSha256': solution['sha256'],\n    'solutionBytes': solution['bytes'],\n    'solutionExists': solution['exists'],\n    'testFileSha256': test_file['sha256'],\n    'testFileBytes': test_file['bytes'],\n    'testFileExists': test_file['exists'],\n}, sort_keys=True))\nPY",
            "timeoutMs": 60000
          },
          "output": {
            "as": {
              "exitCode": "${ .output.result.exitCode // .output.exitCode // 1 }",
              "stdout": "${ .output.result.stdout // .output.stdout // \"\" }",
              "stderr": "${ .output.result.stderr // .output.stderr // \"\" }",
              "raw": "${ .output }"
            }
          }
        }
      }
    ],
    "output": {
      "as": {
        "taskId": "${ .trigger.taskId }",
        "passed": "${ (.run_tests.exitCode // 1) == 0 }",
        "exitCode": "${ .run_tests.exitCode }",
        "stdout": "${ .run_tests.stdout }",
        "stderr": "${ .run_tests.stderr }",
        "pytestOutput": "${ (.run_tests.stdout // \"\") + (if ((.run_tests.stderr // \"\") == \"\") then \"\" else \"\\n\" + .run_tests.stderr end) }",
        "solutionPath": "/sandbox/solution.py",
        "solutionContent": "${ .read_solution.content // \"\" }",
        "solutionSha256": "${ (((.capture_metadata.stdout // \"{}\") | fromjson? | .solutionSha256) // \"\") }",
        "testFileSha256": "${ (((.capture_metadata.stdout // \"{}\") | fromjson? | .testFileSha256) // .trigger.evaluation.expectedOutput.testFileSha256 // \"\") }",
        "runtimeProbe": {
          "exitCode": "${ .validate_runtime.exitCode }",
          "stdout": "${ .validate_runtime.stdout }",
          "stderr": "${ .validate_runtime.stderr }"
        },
        "protocol": {
          "mode": "internal-agent-visible-tests",
          "benchmarkComparable": false
        },
        "raw": {
          "solve": "${ .solve }",
          "validateRuntime": "${ .validate_runtime.raw }",
          "runTests": "${ .run_tests.raw }",
          "readSolution": "${ .read_solution.raw }",
          "captureMetadata": "${ .capture_metadata.raw }"
        },
        "workspaceRef": "${ .workspace_profile.workspaceRef }",
        "sandboxName": "${ .workspace_profile.sandboxName }"
      }
    }
  },
  "nodes": [
    {
      "id": "trigger",
      "type": "trigger",
      "position": { "x": 80, "y": 60 },
      "data": {
        "label": "Eval item trigger",
        "description": "Receives taskId, prompt, expectedOutput.testFileContent, and agentRef from the eval coordinator."
      }
    },
    {
      "id": "workspace_profile",
      "type": "action",
      "position": { "x": 80, "y": 200 },
      "data": {
        "label": "Provision sandbox",
        "actionType": "workspace/profile",
        "description": "Stand up a Python code-eval sandbox with file/exec tools."
      }
    },
    {
      "id": "validate_runtime",
      "type": "action",
      "position": { "x": 80, "y": 340 },
      "data": {
        "label": "Validate runtime",
        "actionType": "workspace/command",
        "description": "Verify pytest and row-declared benchmark libraries are importable before the agent runs."
      }
    },
    {
      "id": "write_test",
      "type": "action",
      "position": { "x": 80, "y": 480 },
      "data": {
        "label": "Write test file",
        "actionType": "workspace/write_file",
        "description": "Drop the eval row's pytest test file at /sandbox/test_solution.py."
      }
    },
    {
      "id": "solve",
      "type": "action",
      "position": { "x": 80, "y": 620 },
      "data": {
        "label": "Agent solves",
        "actionType": "durable/run",
        "description": "Hand the prompt to the published agent. Agent must write its solution to /sandbox/solution.py."
      }
    },
    {
      "id": "restore_test",
      "type": "action",
      "position": { "x": 80, "y": 760 },
      "data": {
        "label": "Restore test file",
        "actionType": "workspace/write_file",
        "description": "Restore the canonical eval test after the agent turn before pytest runs."
      }
    },
    {
      "id": "run_tests",
      "type": "action",
      "position": { "x": 80, "y": 900 },
      "data": {
        "label": "pytest",
        "actionType": "workspace/command",
        "description": "Run pytest on the agent's solution and capture exit code + stdout."
      }
    },
    {
      "id": "read_solution",
      "type": "action",
      "position": { "x": 80, "y": 1040 },
      "data": {
        "label": "Read solution",
        "actionType": "workspace/read_file",
        "description": "Read /sandbox/solution.py after tests for audit and grader inspection."
      }
    },
    {
      "id": "capture_metadata",
      "type": "action",
      "position": { "x": 80, "y": 1180 },
      "data": {
        "label": "Capture hashes",
        "actionType": "workspace/command",
        "description": "Capture solution and test SHA-256 hashes for run inspection."
      }
    }
  ],
  "edges": [
    { "id": "e1", "source": "trigger", "target": "workspace_profile", "type": "default" },
    { "id": "e2", "source": "workspace_profile", "target": "validate_runtime", "type": "default" },
    { "id": "e3", "source": "validate_runtime", "target": "write_test", "type": "default" },
    { "id": "e4", "source": "write_test", "target": "solve", "type": "default" },
    { "id": "e5", "source": "solve", "target": "restore_test", "type": "default" },
    { "id": "e6", "source": "restore_test", "target": "run_tests", "type": "default" },
    { "id": "e7", "source": "run_tests", "target": "read_solution", "type": "default" },
    { "id": "e8", "source": "read_solution", "target": "capture_metadata", "type": "default" }
  ]
}
