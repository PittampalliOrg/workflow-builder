# cli-agent-py sandbox image — host for the `interactive-cli` runtime family
# (claude-code-cli, codex-cli, agy-cli): headless herdr server + the real CLI
# TUI in a herdr pane, Dapr workflow lifecycle host + hooks receiver + WS
# terminal on :8002. ONE image hosts all three CLIs; the BFF stamps
# agentConfig.cliAdapter so the host selects claude / codex / antigravity.
# Modeled on services/claude-agent-py/Dockerfile.sandbox.
ARG OPENSHELL_SANDBOX_IMAGE=ghcr.io/pittampalliorg/openshell-sandbox:git-c390487a6bbcdd1a69cc6d7eb331a4aadaa9692c
# Exact pin (reproducible TUI behavior; DISABLE_AUTOUPDATER below). Bump
# deliberately — 2.1.172 verified on npm 2026-06-10.
ARG CLAUDE_CODE_NPM_VERSION=2.1.172
# OpenAI Codex CLI (npm). OAuth = ChatGPT auth.json (codex-cli adapter); pinned
# binary lives root-owned in the global npm prefix (read-only to uid 10001 →
# self-update can't rewrite it). 0.139.0 verified on npm 2026-06-11.
ARG CODEX_NPM_VERSION=0.139.0
# Antigravity CLI (`agy`). Pinned GitHub release tarball, sha256-verified.
# Binary at /usr/local/bin/agy is root-owned + read-only to uid 10001, which
# defeats agy's background self-update. v1.0.10 verified against GitHub release
# assets on 2026-06-20; bump URL+SHA together per arch.
ARG AGY_VERSION=1.0.10
ARG AGY_URL_AMD64=https://github.com/google-antigravity/antigravity-cli/releases/download/1.0.10/agy_cli_linux_x64.tar.gz
ARG AGY_SHA256_AMD64=6547cf9a37227f26004fa4b805418b1df96f54c57b9723ca7d10864d2610bb0f
ARG AGY_URL_ARM64=https://github.com/google-antigravity/antigravity-cli/releases/download/1.0.10/agy_cli_linux_arm64.tar.gz
ARG AGY_SHA256_ARM64=4674fabc3681221e54c90d15077c9a97a25ea71222001dabe44bf1576e888593
# herdr release binary (AGPL-3.0 — see /usr/share/doc/herdr/LICENSE-note.txt).
# Asset naming verified against the GitHub API on 2026-06-10:
#   https://github.com/ogulcancelik/herdr/releases/download/v<ver>/herdr-linux-x86_64
# HERDR_SHA256 is the GitHub release asset digest for v0.6.8 herdr-linux-x86_64;
# update BOTH args together when bumping (x86_64 only — aarch64 needs its own pair).
ARG HERDR_VERSION=0.6.8
ARG HERDR_SHA256=528d22e889814a6ccf22162801d59690d9dbd5dc64f96d7e1d1c7a8634b25535
ARG HERDR_DOWNLOAD_URL=https://github.com/ogulcancelik/herdr/releases/download/v${HERDR_VERSION}/herdr-linux-x86_64

FROM ghcr.io/astral-sh/uv:0.9.17 AS uv-bin

FROM node:22-bookworm-slim AS node-bin

FROM ${OPENSHELL_SANDBOX_IMAGE}

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git passwd ripgrep \
    && rm -rf /var/lib/apt/lists/*

COPY --from=uv-bin /uv /uvx /usr/local/bin/
COPY --from=node-bin /usr/local/bin/node /usr/local/bin/
COPY --from=node-bin /usr/local/lib/node_modules /usr/local/lib/node_modules
ARG CLAUDE_CODE_NPM_VERSION
ARG CODEX_NPM_VERSION
RUN ln -sf ../lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -sf ../lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx \
    && npm install -g --force "@anthropic-ai/claude-code@${CLAUDE_CODE_NPM_VERSION}" \
    && npm install -g --force "@openai/codex@${CODEX_NPM_VERSION}" \
    && npm cache clean --force \
    && /usr/local/bin/claude --version && /usr/local/bin/codex --version

# Playwright MCP (Node) for the design Critic — lets the critic ACTIVELY drive a
# real browser (navigate / accessibility-snapshot / screenshot) over stdio,
# in-pod, instead of improvising shell + python-playwright. The base
# openshell-sandbox image already ships PYTHON Playwright's Chromium at
# /opt/pw-browsers (PLAYWRIGHT_BROWSERS_PATH, inherited); @playwright/mcp is a
# NODE server whose bundled playwright-core needs its own matching Chromium
# build, installed into the SAME shared dir so the non-root runtime user
# (uid 10001, a+rX) can launch it. `playwright` (CLI) is pinned in lockstep
# with @playwright/mcp@latest so the browser revision matches.
ARG PLAYWRIGHT_MCP_VERSION=latest
RUN npm install -g --force "playwright@latest" "@playwright/mcp@${PLAYWRIGHT_MCP_VERSION}" \
    && PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers npx --yes playwright install chromium \
    && chmod -R a+rX /opt/pw-browsers \
    && npm cache clean --force \
    && /usr/local/bin/npx @playwright/mcp@${PLAYWRIGHT_MCP_VERSION} --version

# R1 persisted recording (automatic): a static @playwright/mcp config that turns
# on Playwright's native per-context video via `contextOptions.recordVideo`. The
# critic passes `--config /etc/playwright-mcp/recordvideo.json` (see
# scripts/seed-workflows.ts PLAYWRIGHT_CRITIC_MCP), so EVERY browser context the
# agent opens records to /sandbox/work — no dependency on the agent calling the
# browser_start_video tool (claude won't reliably do that). cli-agent-py pushes
# the resulting .webm to the BFF browser-artifacts ingest at session end. v0.0.76
# has no `--save-video` flag; recordVideo via --config is the supported path.
RUN mkdir -p /etc/playwright-mcp \
    && printf '%s\n' '{"browser":{"contextOptions":{"recordVideo":{"dir":"/sandbox/work","size":{"width":1280,"height":720}}}}}' \
       > /etc/playwright-mcp/recordvideo.json \
    && chmod a+r /etc/playwright-mcp/recordvideo.json

# agy (Antigravity CLI): pinned, sha256-verified tarball → /usr/local/bin/agy
# (root-owned, read-only to the non-root runtime user, which defeats its
# background self-update). Arch-selected from TARGETARCH.
ARG TARGETARCH
ARG AGY_VERSION
ARG AGY_URL_AMD64
ARG AGY_SHA256_AMD64
ARG AGY_URL_ARM64
ARG AGY_SHA256_ARM64
RUN set -eu; \
    case "${TARGETARCH:-amd64}" in \
      arm64) url="${AGY_URL_ARM64}"; sha="${AGY_SHA256_ARM64}" ;; \
      *)     url="${AGY_URL_AMD64}"; sha="${AGY_SHA256_AMD64}" ;; \
    esac; \
    curl -fsSL -o /tmp/agy.tar.gz "$url"; \
    echo "${sha}  /tmp/agy.tar.gz" | sha256sum -c -; \
    tar -xzf /tmp/agy.tar.gz -C /tmp; \
    install -m 0755 -o root -g root "$(find /tmp -maxdepth 2 -type f -name antigravity | head -1)" /usr/local/bin/agy; \
    rm -rf /tmp/agy.tar.gz /tmp/antigravity; \
    /usr/local/bin/agy --version

# herdr: pinned release binary, sha256-verified, plus the AGPL-3.0 notice.
ARG HERDR_VERSION
ARG HERDR_SHA256
ARG HERDR_DOWNLOAD_URL
RUN curl -fsSL -o /usr/local/bin/herdr "${HERDR_DOWNLOAD_URL}" \
    && echo "${HERDR_SHA256}  /usr/local/bin/herdr" | sha256sum -c - \
    && chmod 0755 /usr/local/bin/herdr
COPY docker/herdr-LICENSE-note.txt /usr/share/doc/herdr/LICENSE-note.txt

WORKDIR /app
COPY pyproject.toml uv.lock ./
RUN uv sync --python /usr/bin/python3 --no-python-downloads --frozen --no-dev
COPY src/ src/

# Static Claude Code hook wiring (every hook event -> the local hooks receiver)
# + CLAUDE_CODE_ENABLE_TELEMETRY. Written in the documented settings schema
# {"hooks": {"EventName": [{"matcher": "*", "hooks": [{"type": "http", "url": ...}]}]}}.
# TODO(claude-cli-smoke): verify the "http" hook type + accepted fields against
# the pinned CLI version (only `url` is set here on purpose).
COPY docker/managed-settings.json /etc/claude-code/managed-settings.json

# Non-root (uid 10001): claude refuses --dangerously-skip-permissions as root.
RUN /usr/sbin/groupadd --gid 10001 cli-agent \
    && /usr/sbin/useradd --create-home --uid 10001 --gid 10001 --shell /bin/bash cli-agent \
    && mkdir -p /sandbox/run /sandbox/.claude /sandbox/.wfb \
        /sandbox/.codex /sandbox/.gemini/config /sandbox/.gemini/antigravity-cli \
        /home/cli-agent/.config/herdr \
    && chown -R cli-agent:cli-agent /app /sandbox /home/cli-agent

# Canonical config lives under /etc (HERDR_CONFIG_PATH) — the pod mounts an
# emptyDir over ${XDG_CONFIG_HOME} (sandbox-execution-api `openshell-config`
# volume at the agentHostUserHome config dir), which would shadow any config
# baked into the home. herdr's runtime files (logs/session.json/socket dir
# metadata) still land under ${XDG_CONFIG_HOME}/herdr inside the emptyDir.
COPY --chown=cli-agent:cli-agent docker/herdr-config.toml /etc/herdr/config.toml

ENV AGENT_SANDBOX_MODE=hybrid \
    AGENT_LOCAL_SANDBOX_ROOT=/sandbox \
    CLI_AGENT_PY_DEFAULT_MODEL=claude-opus-4-8 \
    CLI_AGENT_CLI_PATH=/usr/local/bin/claude \
    CLI_AGENT_CODEX_PATH=/usr/local/bin/codex \
    CLI_AGENT_AGY_PATH=/usr/local/bin/agy \
    CLI_AGENT_AGY_HOME=/sandbox \
    CODEX_HOME=/sandbox/.codex \
    DISABLE_AUTOUPDATER=1 \
    HERDR_SOCKET_PATH=/sandbox/run/herdr.sock \
    HERDR_CONFIG_PATH=/etc/herdr/config.toml \
    CLAUDE_CONFIG_DIR=/sandbox/.claude \
    VIRTUAL_ENV=/app/.venv \
    HOME=/home/cli-agent \
    XDG_CONFIG_HOME=/home/cli-agent/.config \
    PATH="/app/.venv/bin:/usr/local/bin:/usr/bin:/bin"

USER cli-agent

EXPOSE 8002
ENTRYPOINT []
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8002"]
