{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "_comment": "No `matcher` fields on purpose: omitting the matcher means 'always run'. A `\"matcher\": \"*\"` entry silently suppressed SessionStart on the live ryzen E2E (its matcher domain is startup|resume|clear|compact, not tool names) — only the matcher-less events fired. The hooks receiver registers the transcript tailer opportunistically from any event as defense in depth.",
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "PreToolUse": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "PostToolUse": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "PostToolUseFailure": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "PermissionRequest": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "PermissionDenied": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "PreCompact": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ],
    "PostCompact": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:8002/internal/hooks/claude" }] }
    ]
  }
}
