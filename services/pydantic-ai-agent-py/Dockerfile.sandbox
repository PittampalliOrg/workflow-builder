# Per-session sandbox image for the pydantic-ai-agent-py runtime (pod-local
# workspace: harness FileSystem/Shell execute inside this container, rooted
# at /sandbox). git/ripgrep/node for real coding-agent shell work.
FROM ghcr.io/astral-sh/uv:python3.12-trixie-slim
RUN apt-get update && apt-get install -y --no-install-recommends git curl ripgrep && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY pyproject.toml uv.lock* ./
RUN uv sync --frozen --no-dev
COPY src/ src/
RUN mkdir -p /sandbox /mnt/session/outputs
ENV AGENT_SERVICE_NAME=pydantic-ai-agent-py \
    PYDANTIC_AI_WORKSPACE_ROOT=/sandbox
EXPOSE 8002
CMD ["uv", "run", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8002"]
