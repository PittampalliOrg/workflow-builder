{
  "id": "durable-agent-embedded-validation",
  "name": "Durable Agent Embedded Validation",
  "description": "Validate the parent workflow plus embedded durable child agent architecture using the standard durable-agent service.",
  "visibility": "public",
  "spec": {
    "document": {
      "dsl": "1.0.0",
      "namespace": "workflow-builder",
      "name": "durable-agent-embedded-validation",
      "version": "1.0.0",
      "title": "Durable Agent Embedded Validation",
      "summary": "Run a single durable-agent child workflow with a compact loop graph to validate continuity, tracking, and child workflow visualization.",
      "x-workflow-builder": {
        "input": {
          "mode": "single_prompt",
          "promptField": "prompt",
          "promptLabel": "Validation Task",
          "promptPlaceholder": "Describe the task the embedded durable agent should complete inside the validation workspace.",
          "fields": {
            "maxTurns": {
              "type": "select",
              "label": "Max Turns",
              "description": "Iteration budget for the durable child agent.",
              "defaultValue": "8",
              "options": [
                {
                  "label": "6 turns",
                  "value": "6"
                },
                {
                  "label": "8 turns",
                  "value": "8"
                },
                {
                  "label": "12 turns",
                  "value": "12"
                }
              ]
            }
          }
        }
      }
    },
    "do": [
      {
        "durable_validation_run": {
          "call": "durable/run",
          "with": {
            "prompt": "You are validating embedded Dapr DurableAgent execution inside a parent workflow.\n\nUser task:\n{{trigger.prompt}}\n\nExecution rules:\n- Use the execute_command tool only.\n- First inspect the current workspace with `pwd && ls -la`.\n- Then create a directory named validation-output.\n- Then create validation-output/marker.txt containing exactly the line VALIDATION COMPLETE.\n- Then print the file contents and a short directory listing for validation-output.\n- End with a concise summary that includes the exact phrase VALIDATION COMPLETE.\n- Do not use network commands.\n- Do not ask for confirmation.\n",
            "mode": "execute_direct",
            "maxTurns": "{{trigger.maxTurns}}",
            "timeoutMinutes": 15,
            "stopCondition": "Stop only after validation-output/marker.txt exists and the final answer includes the exact phrase VALIDATION COMPLETE.",
            "agentGraph": {
              "version": "v1",
              "nodes": [
                {
                  "id": "input",
                  "position": { "x": 120, "y": 60 },
                  "data": {
                    "label": "Input",
                    "stepType": "input",
                    "config": {}
                  }
                },
                {
                  "id": "decide",
                  "position": { "x": 120, "y": 200 },
                  "data": {
                    "label": "Plan Next Step",
                    "stepType": "decide",
                    "config": {}
                  }
                },
                {
                  "id": "tool-batch",
                  "position": { "x": 120, "y": 340 },
                  "data": {
                    "label": "Execute Command",
                    "stepType": "tool_batch",
                    "config": {}
                  }
                },
                {
                  "id": "memory-write",
                  "position": { "x": 120, "y": 480 },
                  "data": {
                    "label": "Persist State",
                    "stepType": "memory_write",
                    "config": {}
                  }
                },
                {
                  "id": "finish",
                  "position": { "x": 120, "y": 620 },
                  "data": {
                    "label": "Finish",
                    "stepType": "finish",
                    "config": {}
                  }
                }
              ],
              "edges": [
                { "id": "input->decide", "source": "input", "target": "decide" },
                { "id": "decide->tool-batch", "source": "decide", "target": "tool-batch" },
                { "id": "tool-batch->memory-write", "source": "tool-batch", "target": "memory-write" },
                { "id": "memory-write->finish", "source": "memory-write", "target": "finish" }
              ]
            },
            "agentConfig": {
              "name": "durable-embedded-validation",
              "instructions": "Use execute_command to inspect the workspace, create validation-output/marker.txt with the exact text VALIDATION COMPLETE, verify the file, and then stop.",
              "tools": [
                "execute_command"
              ]
            }
          }
        }
      }
    ]
  },
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 260, "y": 20 },
      "data": { "label": "Start", "type": "start", "status": "idle", "enabled": true }
    },
    {
      "id": "durable_validation_run",
      "type": "call",
      "position": { "x": 260, "y": 180 },
      "data": { "label": "Run Durable Agent", "type": "agent", "status": "idle", "enabled": true }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 260, "y": 360 },
      "data": { "label": "Done", "type": "end", "status": "idle", "enabled": true }
    }
  ],
  "edges": [
    { "id": "e-start-durable", "source": "start", "target": "durable_validation_run", "type": "default" },
    { "id": "e-durable-end", "source": "durable_validation_run", "target": "end", "type": "default" }
  ]
}
