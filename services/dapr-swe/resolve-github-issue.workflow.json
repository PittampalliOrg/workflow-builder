{
  "id": "dapr-swe-resolve-issue",
  "name": "Resolve Github Issue",
  "description": "Resolve a GitHub issue with dapr-swe using the canonical SW 1.0 workflow path, then attach UX validation evidence.",
  "visibility": "private",
  "engineType": "dapr",
  "specVersion": "1.0.0",
  "spec": {
    "document": {
      "dsl": "1.0.0",
      "namespace": "workflow-builder",
      "name": "dapr-swe-resolve-issue",
      "version": "1.0.0",
      "title": "Resolve Github Issue",
      "summary": "Issue triage, implementation, review, browser validation, PR, and notification."
    },
    "use": {
      "functions": {
        "initialize": {
          "call": "http",
          "with": {
            "method": "POST",
            "endpoint": {
              "uri": "http://dapr/v1.0/invoke/dapr-swe/method/dapr-swe/initialize"
            }
          }
        },
        "plan": {
          "call": "http",
          "with": {
            "method": "POST",
            "endpoint": {
              "uri": "http://dapr/v1.0/invoke/dapr-swe/method/dapr-swe/plan"
            }
          }
        },
        "develop": {
          "call": "http",
          "with": {
            "method": "POST",
            "endpoint": {
              "uri": "http://dapr/v1.0/invoke/dapr-swe/method/dapr-swe/develop"
            }
          }
        },
        "review": {
          "call": "http",
          "with": {
            "method": "POST",
            "endpoint": {
              "uri": "http://dapr/v1.0/invoke/dapr-swe/method/dapr-swe/review"
            }
          }
        },
        "prepare_preview": {
          "call": "http",
          "with": {
            "method": "POST",
            "endpoint": {
              "uri": "http://dapr/v1.0/invoke/dapr-swe/method/dapr-swe/prepare-preview"
            }
          }
        },
        "report_preview": {
          "call": "http",
          "with": {
            "method": "POST",
            "endpoint": {
              "uri": "http://dapr/v1.0/invoke/dapr-swe/method/dapr-swe/report-preview"
            }
          }
        },
        "browser_validate": {
          "call": "http",
          "with": {
            "method": "POST",
            "endpoint": {
              "uri": "http://dapr/v1.0/invoke/openshell-agent-runtime/method/browser/validate"
            }
          }
        },
        "commit_pr": {
          "call": "http",
          "with": {
            "method": "POST",
            "endpoint": {
              "uri": "http://dapr/v1.0/invoke/dapr-swe/method/dapr-swe/commit-pr"
            }
          }
        },
        "notify": {
          "call": "http",
          "with": {
            "method": "POST",
            "endpoint": {
              "uri": "http://dapr/v1.0/invoke/dapr-swe/method/dapr-swe/notify"
            }
          }
        }
      }
    },
    "do": [
      {
        "initialize": {
          "call": "initialize",
          "with": {
            "provider": "${ .input.provider // \"github\" }",
            "owner": "${ .input.owner }",
            "repo": "${ .input.repo }",
            "issue_number": "${ .input.issue_number }",
            "title": "${ .input.title }",
            "body": "${ .input.body // \"\" }",
            "comments": "${ .input.comments // [] }",
            "labels": "${ .input.labels // [] }",
            "sender": "${ .input.sender // \"\" }",
            "installation_id": "${ .input.installation_id // 0 }",
            "baseBranch": "${ .input.base_branch // .input.baseBranch // \"main\" }"
          }
        }
      },
      {
        "plan": {
          "call": "plan",
          "with": {
            "provider": "${ .initialize.provider }",
            "owner": "${ .input.owner }",
            "repo": "${ .input.repo }",
            "issue_number": "${ .input.issue_number }",
            "title": "${ .input.title }",
            "body": "${ .input.body // \"\" }",
            "comments": "${ .input.comments // [] }",
            "sender": "${ .input.sender // \"\" }",
            "sandbox_id": "${ .initialize.sandbox_id }",
            "working_dir": "${ .initialize.working_dir }",
            "agents_md": "${ .initialize.agents_md // \"\" }",
            "github_token": "${ .initialize.github_token // \"\" }",
            "gitea_username": "${ .initialize.gitea_username // \"\" }",
            "gitea_token": "${ .initialize.gitea_token // \"\" }"
          }
        }
      },
      {
        "implement": {
          "call": "develop",
          "with": {
            "provider": "${ .initialize.provider }",
            "owner": "${ .input.owner }",
            "repo": "${ .input.repo }",
            "issue_number": "${ .input.issue_number }",
            "title": "${ .input.title }",
            "body": "${ .input.body // \"\" }",
            "comments": "${ .input.comments // [] }",
            "sender": "${ .input.sender // \"\" }",
            "sandbox_id": "${ .initialize.sandbox_id }",
            "working_dir": "${ .initialize.working_dir }",
            "agents_md": "${ .initialize.agents_md // \"\" }",
            "github_token": "${ .initialize.github_token // \"\" }",
            "gitea_username": "${ .initialize.gitea_username // \"\" }",
            "gitea_token": "${ .initialize.gitea_token // \"\" }",
            "plan": "${ .plan.plan }"
          }
        }
      },
      {
        "review": {
          "call": "review",
          "with": {
            "owner": "${ .input.owner }",
            "repo": "${ .input.repo }",
            "issue_number": "${ .input.issue_number }",
            "title": "${ .input.title }",
            "body": "${ .input.body // \"\" }",
            "sandbox_id": "${ .initialize.sandbox_id }",
            "working_dir": "${ .initialize.working_dir }",
            "plan": "${ .plan.plan }"
          }
        }
      },
      {
        "prepare_preview": {
          "call": "prepare_preview",
          "with": {
            "sandbox_id": "${ .initialize.sandbox_id }",
            "working_dir": "${ .initialize.working_dir }"
          }
        }
      },
      {
        "preview_route": {
          "switch": [
            {
              "should_validate": {
                "when": "${ .prepare_preview.should_validate == true }",
                "then": "preview_started"
              }
            },
            {
              "skip_validation": {
                "then": "commit_pr"
              }
            }
          ]
        }
      },
      {
        "preview_started": {
          "call": "report_preview",
          "with": {
            "stage": "started",
            "appSubdir": "${ .prepare_preview.appSubdir // \".\" }"
          }
        }
      },
      {
        "preview_capture": {
          "try": [
            {
              "validate": {
                "call": "browser_validate",
                "with": {
                  "workspaceRef": "${ .prepare_preview.workspaceRef }",
                  "repoPath": "${ .prepare_preview.repoPath }",
                  "installCommand": "${ .prepare_preview.installCommand // \"\" }",
                  "devServerCommand": "${ .prepare_preview.devServerCommand // \"\" }",
                  "baseUrl": "${ .prepare_preview.baseUrl // \"http://127.0.0.1:3009\" }",
                  "steps": "${ .prepare_preview.steps // [] }",
                  "captureTrace": "${ .prepare_preview.captureTrace // true }",
                  "captureVideo": "${ .prepare_preview.captureVideo // true }",
                  "viewportPreset": "${ .prepare_preview.viewportPreset // \"desktop\" }",
                  "timeoutMs": 900000
                }
              }
            }
          ],
          "output": {
            "as": {
              "status": "${ .\"preview_capture/try/validate\".data.data.result.status // .\"preview_capture/try/validate\".status // (if .task.success then \"completed\" else \"failed\" end) }",
              "artifactId": "${ .\"preview_capture/try/validate\".data.data.result.artifactId // .\"preview_capture/try/validate\".artifactId // \"\" }",
              "screenshots": "${ .\"preview_capture/try/validate\".data.data.result.screenshots // .\"preview_capture/try/validate\".screenshots // 0 }",
              "traceAssetRef": "${ ((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // .\"preview_capture/try/validate\".artifact.manifestJson.assets // []) | map(select(.kind == \"trace\"))[0].storageRef) // \"\" }",
              "videoAssetRef": "${ ((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // .\"preview_capture/try/validate\".artifact.manifestJson.assets // []) | map(select(.kind == \"video\"))[0].storageRef) // \"\" }",
              "artifact": "${ .\"preview_capture/try/validate\".data.data.result.artifact // .\"preview_capture/try/validate\".artifact // null }",
              "error": "${ .\"preview_capture/try/validate\".data.data.result.error // .\"preview_capture/try/validate\".error // .task.error // \"\" }",
              "phase": "${ .\"preview_capture/try/validate\".data.data.result.phase // .\"preview_capture/try/validate\".phase // \"\" }"
            }
          }
        }
      },
      {
        "preview_complete": {
          "call": "report_preview",
          "with": {
            "stage": "completed",
            "appSubdir": "${ .prepare_preview.appSubdir // \".\" }",
            "validation": "${ if .prepare_preview.should_validate then {status:(.\"preview_capture/try/validate\".data.data.result.status // \"failed\"), artifactId:(.\"preview_capture/try/validate\".data.data.result.artifactId // \"\"), screenshots:(.\"preview_capture/try/validate\".data.data.result.screenshots // 0), traceAssetRef:(((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // []) | map(select(.kind == \"trace\"))[0].storageRef) // \"\"), videoAssetRef:(((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // []) | map(select(.kind == \"video\"))[0].storageRef) // \"\"), artifact:(.\"preview_capture/try/validate\".data.data.result.artifact // null), error:(.\"preview_capture/try/validate\".data.data.result.error // \"\"), phase:(.\"preview_capture/try/validate\".data.data.result.phase // \"\")} else {status:\"skipped\", error:(.prepare_preview.reason // \"Preview validation not applicable.\")} end }"
          }
        }
      },
      {
        "commit_pr": {
          "call": "commit_pr",
          "with": {
            "provider": "${ .initialize.provider }",
            "owner": "${ .input.owner }",
            "repo": "${ .input.repo }",
            "issue_number": "${ .input.issue_number }",
            "title": "${ .input.title }",
            "baseBranch": "${ .input.base_branch // .input.baseBranch // \"main\" }",
            "sandbox_id": "${ .initialize.sandbox_id }",
            "working_dir": "${ .initialize.working_dir }",
            "github_token": "${ .initialize.github_token // \"\" }",
            "gitea_username": "${ .initialize.gitea_username // \"\" }",
            "gitea_token": "${ .initialize.gitea_token // \"\" }",
            "plan": "${ .plan.plan }",
            "review": "${ .review }",
            "validation": "${ if .prepare_preview.should_validate then {status:(.\"preview_capture/try/validate\".data.data.result.status // \"failed\"), artifactId:(.\"preview_capture/try/validate\".data.data.result.artifactId // \"\"), screenshots:(.\"preview_capture/try/validate\".data.data.result.screenshots // 0), traceAssetRef:(((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // []) | map(select(.kind == \"trace\"))[0].storageRef) // \"\"), videoAssetRef:(((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // []) | map(select(.kind == \"video\"))[0].storageRef) // \"\"), artifact:(.\"preview_capture/try/validate\".data.data.result.artifact // null), error:(.\"preview_capture/try/validate\".data.data.result.error // \"\"), phase:(.\"preview_capture/try/validate\".data.data.result.phase // \"\")} else {status:\"skipped\", error:(.prepare_preview.reason // \"Preview validation not applicable.\")} end }"
          }
        }
      },
      {
        "notify": {
          "call": "notify",
          "with": {
            "provider": "${ .initialize.provider }",
            "owner": "${ .input.owner }",
            "repo": "${ .input.repo }",
            "issue_number": "${ .input.issue_number }",
            "status": "${ .commit_pr.status }",
            "pr_url": "${ .commit_pr.pr_url // \"\" }",
            "error": "${ .commit_pr.error // \"\" }",
            "review": "${ .review }",
            "validation": "${ if .prepare_preview.should_validate then {status:(.\"preview_capture/try/validate\".data.data.result.status // \"failed\"), artifactId:(.\"preview_capture/try/validate\".data.data.result.artifactId // \"\"), screenshots:(.\"preview_capture/try/validate\".data.data.result.screenshots // 0), traceAssetRef:(((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // []) | map(select(.kind == \"trace\"))[0].storageRef) // \"\"), videoAssetRef:(((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // []) | map(select(.kind == \"video\"))[0].storageRef) // \"\"), artifact:(.\"preview_capture/try/validate\".data.data.result.artifact // null), error:(.\"preview_capture/try/validate\".data.data.result.error // \"\"), phase:(.\"preview_capture/try/validate\".data.data.result.phase // \"\")} else {status:\"skipped\", error:(.prepare_preview.reason // \"Preview validation not applicable.\")} end }"
          }
        }
      }
    ],
    "output": {
      "as": {
        "status": "${ .notify.status // .commit_pr.status // \"failed\" }",
        "prUrl": "${ .commit_pr.pr_url // \"\" }",
        "branch": "${ .commit_pr.branch // \"\" }",
        "review": "${ .review }",
        "validation": "${ if .prepare_preview.should_validate then {status:(.\"preview_capture/try/validate\".data.data.result.status // \"failed\"), artifactId:(.\"preview_capture/try/validate\".data.data.result.artifactId // \"\"), screenshots:(.\"preview_capture/try/validate\".data.data.result.screenshots // 0), traceAssetRef:(((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // []) | map(select(.kind == \"trace\"))[0].storageRef) // \"\"), videoAssetRef:(((.\"preview_capture/try/validate\".data.data.result.artifact.manifestJson.assets // []) | map(select(.kind == \"video\"))[0].storageRef) // \"\"), artifact:(.\"preview_capture/try/validate\".data.data.result.artifact // null), error:(.\"preview_capture/try/validate\".data.data.result.error // \"\"), phase:(.\"preview_capture/try/validate\".data.data.result.phase // \"\")} else {status:\"skipped\", error:(.prepare_preview.reason // \"Preview validation not applicable.\")} end }"
      }
    }
  },
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 80, "y": 120 },
      "data": { "label": "Start", "type": "start", "status": "idle", "enabled": true }
    },
    {
      "id": "initialize",
      "type": "call",
      "position": { "x": 280, "y": 120 },
      "data": { "label": "Initialize", "type": "call", "status": "idle", "enabled": true }
    },
    {
      "id": "plan",
      "type": "call",
      "position": { "x": 500, "y": 120 },
      "data": { "label": "Plan", "type": "call", "status": "idle", "enabled": true }
    },
    {
      "id": "implement",
      "type": "call",
      "position": { "x": 720, "y": 120 },
      "data": { "label": "Implement", "type": "call", "status": "idle", "enabled": true }
    },
    {
      "id": "review",
      "type": "call",
      "position": { "x": 940, "y": 120 },
      "data": { "label": "Review", "type": "call", "status": "idle", "enabled": true }
    },
    {
      "id": "prepare_preview",
      "type": "call",
      "position": { "x": 1160, "y": 120 },
      "data": { "label": "Prepare Preview", "type": "call", "status": "idle", "enabled": true }
    },
    {
      "id": "preview_route",
      "type": "switch",
      "position": { "x": 1380, "y": 120 },
      "data": { "label": "Preview?", "type": "switch", "status": "idle", "enabled": true }
    },
    {
      "id": "preview_capture",
      "type": "try",
      "position": { "x": 1600, "y": 40 },
      "data": { "label": "Capture UX", "type": "try", "status": "idle", "enabled": true }
    },
    {
      "id": "commit_pr",
      "type": "call",
      "position": { "x": 1600, "y": 220 },
      "data": { "label": "Commit & PR", "type": "call", "status": "idle", "enabled": true }
    },
    {
      "id": "notify",
      "type": "call",
      "position": { "x": 1820, "y": 220 },
      "data": { "label": "Notify", "type": "call", "status": "idle", "enabled": true }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 2040, "y": 220 },
      "data": { "label": "Done", "type": "end", "status": "idle", "enabled": true }
    }
  ],
  "edges": [
    { "id": "e-start-initialize", "source": "start", "target": "initialize" },
    { "id": "e-initialize-plan", "source": "initialize", "target": "plan" },
    { "id": "e-plan-implement", "source": "plan", "target": "implement" },
    { "id": "e-implement-review", "source": "implement", "target": "review" },
    { "id": "e-review-prepare", "source": "review", "target": "prepare_preview" },
    { "id": "e-prepare-route", "source": "prepare_preview", "target": "preview_route" },
    { "id": "e-route-preview", "source": "preview_route", "target": "preview_capture" },
    { "id": "e-route-commit", "source": "preview_route", "target": "commit_pr" },
    { "id": "e-preview-commit", "source": "preview_capture", "target": "commit_pr" },
    { "id": "e-commit-notify", "source": "commit_pr", "target": "notify" },
    { "id": "e-notify-end", "source": "notify", "target": "end" }
  ]
}
