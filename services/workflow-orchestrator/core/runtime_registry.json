{
  "version": 1,
  "_comment": "Canonical declarative registry of durable-agent runtimes (DurableSessionRuntime contract, Phase 1). Replaces the scattered _NATIVE_DURABLE_AGENT_TARGETS dict + resolver ladder in sw_workflow.py. app-ids are NOT frozen here — each is resolved at load from core.config (Dapr Configuration / env), so the existing config-override flow is unchanged; only the static `capabilities` blob is new. dispatchWorkflowName + bridgeGateToken are global (the two-name dispatch: the literal workflow dispatched is `session_workflow`; the bridge-eligibility sentinel is `agent_workflow` == config.DURABLE_AGENT_CHILD_WORKFLOW_RUN_NAME). Phase 2 promotes this file to services/shared/runtime-registry.json and adds a TS reader; capability flags are advisory until the Phase 3 swap-safety gate consumes them and the Phase 5 conformance harness verifies them (capabilitiesVerified).",
  "dispatchWorkflowName": "session_workflow",
  "bridgeGateTokenConfigKey": "DURABLE_AGENT_CHILD_WORKFLOW_RUN_NAME",
  "defaultRuntimeId": "dapr-agent-py",
  "runtimes": [
    {
      "id": "dapr-agent-py",
      "appIdConfigKey": "DAPR_AGENT_PY_APP_ID",
      "instancePrefix": "durable",
      "family": "durable-session",
      "mainContainerName": "dapr-agent-py",
      "imageEnvKey": "AGENT_RUNTIME_DAPR_DEFAULT_IMAGE",
      "agentMetadataFramework": "Dapr Agents",
      "benchmarkEligible": true,
      "capabilitiesVerified": true,
      "capabilities": {
        "durabilityGranularity": "per-activity",
        "retryMaxAttempts": 8,
        "durableTurnTimer": false,
        "supportsMcp": true,
        "supportsBuiltinOpenShellTools": true,
        "supportsHooks": true,
        "hookTiming": "live",
        "supportsPermissionGating": true,
        "supportsPlugins": true,
        "supportsCompaction": true,
        "incrementalEvents": true,
        "ownsSandbox": false,
        "requiresWarmPool": false,
        "requiresBrowserSidecars": false,
        "multiProvider": true,
        "supportedProviders": [
          "anthropic", "openai", "deepseek", "nvidia", "kimi",
          "alibaba", "together", "gemini", "foundry"
        ]
      }
    },
