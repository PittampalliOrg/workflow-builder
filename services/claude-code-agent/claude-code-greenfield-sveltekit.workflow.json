{
  "id": "claude-code-greenfield-sveltekit",
  "name": "Claude Code Greenfield SvelteKit",
  "description": "Create and validate a SvelteKit app with the custom Claude Code durable runtime in a canonical OpenShell workspace.",
  "visibility": "public",
  "spec": {
    "document": {
      "dsl": "1.0.0",
      "namespace": "workflow-builder",
      "name": "claude-code-greenfield-sveltekit",
      "version": "2.0.0",
      "title": "Claude Code Greenfield SvelteKit",
      "summary": "Provision OpenShell workspace, run Claude Code as a durable child workflow, then capture browser evidence from the same workspace.",
      "x-workflow-builder": {
        "input": {
          "mode": "single_prompt",
          "promptField": "prompt",
          "promptLabel": "Prompt",
          "promptPlaceholder": "Describe the SvelteKit app you want Claude Code to build.",
          "fields": {
            "model": {
              "type": "select",
              "label": "Claude Model",
              "defaultValue": "anthropic/claude-sonnet-4-20250514",
              "options": [
                { "label": "Sonnet 4", "value": "anthropic/claude-sonnet-4-20250514" },
                { "label": "Opus 4.6", "value": "anthropic/claude-opus-4-6" },
                { "label": "Sonnet 4.6", "value": "anthropic/claude-sonnet-4-6" }
              ]
            }
          }
        }
      }
    },
    "do": [
      {
        "workspace_profile": {
          "call": "workspace/profile",
          "with": {
            "name": "claude-code-greenfield-sveltekit",
            "rootPath": "/sandbox",
            "commandTimeoutMs": 600000,
            "timeoutMs": 900000,
            "sandboxTemplate": "openshell-browser",
            "enabledTools": [
              "execute_command",
              "read_file",
              "write_file",
              "edit_file",
              "list_files",
              "mkdir",
              "file_stat"
            ]
          }
        }
      },
      {
        "claude_code_build": {
          "call": "durable/run",
          "with": {
            "agentRuntime": "claude-code-agent",
            "workspaceRef": "{{workspace_profile.workspaceRef}}",
            "cwd": "/sandbox/{{trigger.repo}}",
            "model": "{{trigger.model}}",
            "mode": "execute_direct",
            "maxTurns": 24,
            "timeoutMinutes": 45,
            "stopCondition": "Stop only after /sandbox/{{trigger.repo}} contains a working SvelteKit app, npm install has succeeded, npm run build has succeeded, and the final response includes SVELTEKIT APP VALIDATED.",
            "prompt": "Build a SvelteKit app in the explicit OpenShell workspace.\n\nUser prompt:\n{{trigger.prompt}}\n\nExecution rules:\n- Use Bash, Read, Write, Edit, Glob, and Grep only.\n- Work only in /sandbox/{{trigger.repo}}.\n- Create /sandbox/{{trigger.repo}} if it does not exist.\n- Create a modern SvelteKit app with package.json, svelte.config.js, vite.config.js, src/app.html, and src/routes/+page.svelte.\n- Include data-demo=\"app-shell\" on the main application container, data-demo=\"primary-action\" on a visible interactive control, and data-demo=\"demo-state\" on a visible region that changes after the interaction.\n- Use npm scripts: dev, build, preview, and check.\n- Run npm install and npm run build before finishing.\n- Do not use network commands except npm package installation.\n- End with a concise final answer that includes SVELTEKIT APP VALIDATED.",
            "agentConfig": {
              "name": "claude-code-greenfield-sveltekit",
              "runtime": "claude-code-agent",
              "instructions": "You are the custom Claude Code agent harness running through Dapr durable workflow activities. Build and validate the requested SvelteKit app using the OpenShell-backed workspace tools.",
              "tools": ["Bash", "Read", "Write", "Edit", "Glob", "Grep"],
              "loop": { "strategy": "graph_v1" },
              "memory": { "backend": "dapr_state", "sessionId": "claude-code-greenfield-sveltekit" }
            }
          }
        }
      },
      {
        "browser_capture": {
          "call": "browser/validate",
          "with": {
            "workspaceRef": "{{workspace_profile.workspaceRef}}",
            "repoPath": "/sandbox/{{trigger.repo}}",
            "installCommand": "npm install --no-audit --no-fund --loglevel=warn",
            "baseUrl": "http://127.0.0.1:3009",
            "steps": [
              {
                "id": "home",
                "label": "Home",
                "action": "visit",
                "path": "/",
                "goal": "Show the initial application shell.",
                "waitForSelector": "[data-demo=\"app-shell\"]",
                "pauseMs": 1200,
                "fullPage": true
              },
              {
                "id": "primary-action",
                "label": "Primary Interaction",
                "action": "click",
                "selector": "[data-demo=\"primary-action\"]",
                "goal": "Trigger the app interaction.",
                "waitForSelector": "[data-demo=\"demo-state\"]",
                "pauseMs": 1200,
                "fullPage": false
              },
              {
                "id": "final",
                "label": "Final Overview",
                "action": "assert",
                "waitForSelector": "[data-demo=\"app-shell\"]",
                "goal": "Capture the final state of the application.",
                "pauseMs": 1200,
                "fullPage": true
              }
            ],
            "captureVideo": true,
            "captureTrace": true,
            "viewportPreset": "desktop",
            "captureMode": "demo",
            "demoTitle": "{{trigger.repo}}",
            "demoSummary": "{{trigger.prompt}}",
            "timeoutMs": 600000
          }
        }
      }
    ]
  },
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 260, "y": 20 },
      "data": { "label": "Start", "type": "start", "status": "idle", "enabled": true }
    },
    {
      "id": "workspace_profile",
      "type": "call",
      "position": { "x": 260, "y": 140 },
      "data": { "label": "OpenShell Workspace", "type": "call", "status": "idle", "enabled": true }
    },
    {
      "id": "claude_code_build",
      "type": "call",
      "position": { "x": 260, "y": 300 },
      "data": { "label": "Claude Code Build", "type": "agent", "status": "idle", "enabled": true }
    },
    {
      "id": "browser_capture",
      "type": "call",
      "position": { "x": 260, "y": 460 },
      "data": { "label": "Browser Capture", "type": "call", "status": "idle", "enabled": true }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 260, "y": 620 },
      "data": { "label": "Done", "type": "end", "status": "idle", "enabled": true }
    }
  ],
  "edges": [
    { "id": "e1", "source": "start", "target": "workspace_profile" },
    { "id": "e2", "source": "workspace_profile", "target": "claude_code_build" },
    { "id": "e3", "source": "claude_code_build", "target": "browser_capture" },
    { "id": "e4", "source": "browser_capture", "target": "end" }
  ]
}
