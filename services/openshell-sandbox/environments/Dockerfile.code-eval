# syntax=docker/dockerfile:1.7

ARG BASE_IMAGE
ARG PYTHON_VERSION=3.10
FROM ghcr.io/astral-sh/uv:0.9.17 AS uv-bin

# Sandbox environment for HumanEval+, MBPP+, and BigCodeBench evals.
# Each eval row mounts a test_solution.py + has the agent write
# /sandbox/solution.py, then we run pytest against it. This image bakes the
# pytest + evalplus + bigcodebench library pool so individual rows don't
# pay a 60-90s pip install. ~2 GB extra over the base openshell-sandbox.
#
# The library list comes from BigCodeBench's requirements; HumanEval+/MBPP+
# don't need extras beyond stdlib but BigCodeBench tasks call 139 third-party
# libs, so we install the most common ones up front.

# GitOps must provide a pinned base image tag or digest. Do not default to
# :latest; benchmark runtime changes need auditable image provenance.
FROM ${BASE_IMAGE}
ARG PYTHON_VERSION

# System package layers run as root; drop back to the sandbox user at the end
# so the image matches OpenShell's runtime expectations.
USER root
COPY --from=uv-bin /uv /uvx /usr/local/bin/

# Build toolchain + headers BigCodeBench tasks expect (numpy/scipy/cryptography
# wheels are usually prebuilt for x86_64 manylinux, but several niche tasks
# require source builds — keep gcc + python-dev around).
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    DEBIAN_FRONTEND=noninteractive apt-get update -qq \
 && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    build-essential python3-dev libffi-dev libssl-dev pkg-config curl \
 && rm -rf /var/lib/apt/lists/*

# Create the benchmark venv at image build time with a fixed Python 3.10
# runtime, then install pytest + EvalPlus + BigCodeBench top-of-funnel
# libraries. We read tasks via HuggingFace and run pytest directly in the
# internal agent-visible mode, so the official Docker evaluator is not part of
# the default sandbox path.
ENV VIRTUAL_ENV=/sandbox/.venv
ENV PATH="/sandbox/.venv/bin:${PATH}"
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    rm -rf /sandbox/.venv \
 && uv venv --seed --python "${PYTHON_VERSION}" /sandbox/.venv \
 && /sandbox/.venv/bin/python -m pip install --upgrade --no-compile --disable-pip-version-check pip setuptools wheel \
 && /sandbox/.venv/bin/python -m pip install --no-compile --disable-pip-version-check \
    pytest pytest-timeout evalplus \
    numpy pandas scipy scikit-learn matplotlib pillow \
    requests beautifulsoup4 lxml \
    sympy networkx \
    flask jinja2 pyyaml \
    python-dateutil regex tqdm \
    cryptography \
    nltk

# Drop back to the sandbox user so OpenShell's policy (run_as_user: sandbox)
# matches what the image actually runs as. The sandbox user is defined in the
# root openshell-sandbox image.
USER sandbox
WORKDIR /sandbox
