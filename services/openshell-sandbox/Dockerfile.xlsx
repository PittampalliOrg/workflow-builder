FROM ghcr.io/nvidia/openshell-community/sandboxes/base:latest

USER root

# xlsx-capable sandbox image for spreadsheet skills and workflows. LibreOffice
# is intentionally baked into the image because OpenShell agent commands run as
# the unprivileged `sandbox` user and cannot install OS packages at runtime.
RUN apt-get update && apt-get install -y --no-install-recommends \
    fonts-dejavu \
    fonts-liberation \
    libnss3 \
    libatk-bridge2.0-0 \
    libdrm2 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libgbm1 \
    libasound2t64 \
    libpangocairo-1.0-0 \
    libgtk-3-0t64 \
    libreoffice-calc \
    python3-pip \
    xvfb \
    && rm -rf /var/lib/apt/lists/*

ENV PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
RUN pip install --break-system-packages --no-cache-dir \
    openpyxl \
    pandas \
    playwright \
    xlsxwriter \
    && playwright install --with-deps chromium \
    && chmod -R a+rX /opt/pw-browsers \
    && rm -rf /var/lib/apt/lists/*
