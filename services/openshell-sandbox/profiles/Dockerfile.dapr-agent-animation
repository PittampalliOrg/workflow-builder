# syntax=docker/dockerfile:1.7

# Sandbox profile: dapr-agent-animation
# Name: Manim animation
# Pre-baked 3B1B / Manim stack — adds ffmpeg, cairo/pango build deps, and
# Python packages (manim, numpy, matplotlib, pillow) into /sandbox/.venv so
# an agent can `import manim` on turn 1 without hitting the OpenShell
# client.exec pip-install 403. Matches NVIDIA's documented "bake system deps
# into the image" pattern.
#
# This file is the seed for the admin console generator. Future edits can be
# made in the admin UI (/admin/sandbox-profiles/<id>) which regenerates this
# file server-side. DO NOT edit by hand once the profile is managed.

ARG BASE_IMAGE=gitea-ryzen.tail286401.ts.net/giteaadmin/openshell-sandbox:latest
FROM ${BASE_IMAGE}

# System package layers run as root; drop back to the sandbox user at the end.
USER root

# apt layer — system libs Manim's native extensions link against at pip-
# install time (pycairo needs libcairo, manimpango needs libpango,
# build-essential covers the C compiler + pkg-config).
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    DEBIAN_FRONTEND=noninteractive apt-get update -qq \
 && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    ffmpeg \
    libcairo2-dev \
    libpango1.0-dev \
    pkg-config \
    python3-dev \
    build-essential \
 && rm -rf /var/lib/apt/lists/*

# pip layer — into /sandbox/.venv (already created by uv in the base image).
# BuildKit cache mount on ~/.cache/pip so incremental rebuilds (add one
# package) complete in seconds rather than re-downloading wheels.
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    /sandbox/.venv/bin/pip install --no-compile --disable-pip-version-check \
    manim \
    numpy \
    matplotlib \
    pillow

USER sandbox
WORKDIR /sandbox
