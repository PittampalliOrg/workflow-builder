# syntax=docker/dockerfile:1.7
# Dev image for `skaffold dev -m workflow-builder`.
#
# Skaffold's mental model: image is source of truth at pod start time; sync
# delivers SUBSEQUENT changes (no initial sync into a running pod). So src/,
# lib/, etc. must be baked in. Sync rules in workflow-builder.skaffold.yaml
# determine which files trigger sync-only updates vs full image rebuild.
#
# Layer order is cache-optimised: pnpm install (slowest, rarely changes) →
# rarely-edited config files → frequently-edited app source.

ARG PNPM_VERSION=9.12.3

FROM node:22-alpine

WORKDIR /app

# Build dependencies as root, then hand the writable development tree to the
# restricted runtime UID used by preview namespaces.
USER root

# Install one runtime-visible pnpm binary. Preview pods run as UID 1001, so a
# root-scoped Corepack activation is not visible to dependency hot-sync actions.
ARG PNPM_VERSION
RUN npm install -g pnpm@${PNPM_VERSION}
ENV npm_config_store_dir=/app/.pnpm-store

# Dependency layer: changing package.json or pnpm-lock.yaml busts this layer
# and forces Skaffold to rebuild + redeploy the pod (matches devspace
# onUpload.exec install behaviour).
COPY package.json ./
COPY pnpm-lock.yaml ./
COPY .npmrc ./
RUN --mount=type=cache,target=/app/.pnpm-store \
    pnpm install --frozen-lockfile --ignore-scripts

# Project config layer (rarely changes).
COPY svelte.config.js vite.config.ts tsconfig.json components.json drizzle.config.ts server-prod.js ./

# App source layer (changes most often). Sync rules in
# workflow-builder.skaffold.yaml deliver per-file updates on top of these
# baked copies without rebuilding the image.
COPY drizzle ./drizzle
COPY scripts ./scripts
COPY static ./static
COPY lib ./lib
COPY src ./src

# B4 contract flow: bake the shared TS↔Python workflow-data contract fixtures. The
# contract vitest reads them from process.cwd()/services/shared/... (= /app here);
# the sync client (registry syncPaths includes this path) re-syncs live edits so a
# fixture change can be re-checked in-pod via `/__run?cmd=contract`.
COPY services/shared/workflow-data-contract ./services/shared/workflow-data-contract

# #40 exec bridge: /__run commands execute HERE (the app container's real
# toolchain: node_modules, pnpm) instead of the node-only dev-sync-sidecar.
# Lives OUTSIDE /app so the sidecar-transport emptyDir mount can never mask it.
# Started as a background child of the entrypoint; binds 127.0.0.1 only and
# fails closed without DEV_SYNC_COMMANDS_JSON (plain `skaffold dev` unaffected).
COPY services/dev-sync-sidecar/exec-bridge.mjs /devtools/exec-bridge.mjs

RUN addgroup -g 1001 dev-runtime \
    && adduser -D -u 1001 -G dev-runtime dev-runtime \
    && chown -R 1001:1001 /app /devtools

ENV NODE_ENV=development
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV HOME=/home/dev-runtime

EXPOSE 3000 24678

USER 1001:1001

# vite is installed under node_modules/.bin by pnpm above.
# --host 0.0.0.0 binds inside the pod; the Service forwards from cluster
# traffic. --port 3000 matches the prod container's exposed port so the
# Service/Ingress need no changes.
# The exec bridge is a background child; `exec` keeps vite as PID 1 (a bridge
# crash never takes the dev server down, and vice versa).
CMD ["sh", "-c", "node /devtools/exec-bridge.mjs & exec /app/node_modules/.bin/vite dev --host 0.0.0.0 --port 3000"]
