# syntax=docker/dockerfile:1.7
# Dev image for `skaffold dev -m function-router`.
ARG PNPM_VERSION=9.12.3

FROM node:22-alpine

WORKDIR /app
USER root

ARG PNPM_VERSION
RUN npm install -g pnpm@${PNPM_VERSION}
ENV npm_config_store_dir=/app/.pnpm-store

COPY services/function-router/package.json ./
COPY services/function-router/pnpm-lock.yaml ./
RUN --mount=type=cache,target=/app/.pnpm-store \
    pnpm install --frozen-lockfile --ignore-scripts

COPY services/function-router/ ./

# Baseline capture-only build inputs in the same hidden paths used by sync.sh.
# Receiver diff receipts can then distinguish unchanged transport files from edits.
COPY services/function-router/Dockerfile /app/.preview-capture/production.Dockerfile
COPY skaffold/dev/function-router/Dockerfile.dev /app/.preview-capture/development.Dockerfile

# #40 exec bridge: /__run commands (registry `deps` = pnpm install) execute
# HERE with the app container's pnpm/node_modules instead of the bare
# dev-sync-sidecar. Outside /app so the emptyDir workdir mount can't mask it;
# 127.0.0.1-only; fails closed without DEV_SYNC_COMMANDS_JSON.
COPY services/dev-sync-sidecar/exec-bridge.mjs /devtools/exec-bridge.mjs

RUN addgroup -g 1001 dev-runtime \
    && adduser -D -u 1001 -G dev-runtime dev-runtime \
    && chown -R 1001:1001 /app /devtools

ENV NODE_ENV=development
ENV PORT=8080
ENV HOME=/home/dev-runtime

EXPOSE 8080

USER 1001:1001

# Start the baked watcher directly so boot never performs package-manager
# reconciliation. The pinned global pnpm remains available to the allowlisted
# dependency action after a manifest sync.
CMD ["sh", "-c", "node /devtools/exec-bridge.mjs & exec /app/node_modules/.bin/tsx watch src/index.ts"]
