# syntax=docker/dockerfile:1.7
# Dev image for `skaffold dev -m workflow-orchestrator`.
# Source-of-truth at image-build time; sync delivers subsequent file changes.

FROM python:3.12-slim

WORKDIR /app
USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

# Dependency layer (cached unless requirements.txt changes). pytest is added for
# the B4 in-pod contract lane (`/__run?cmd=contract`); it is a dev-only dep, so it
# is not in the prod requirements.txt.
COPY services/workflow-orchestrator/requirements.txt /tmp/requirements.txt
RUN --mount=type=cache,target=/root/.cache/pip \
    python -m venv /app/.venv \
    && /app/.venv/bin/pip install --upgrade pip \
    && /app/.venv/bin/pip install -r /tmp/requirements.txt \
    && /app/.venv/bin/pip install pytest

# Source layer — sync rules deliver per-file updates on top of these baked copies.
COPY services/workflow-orchestrator/ ./

# B4 contract flow: bake the shared TS↔Python workflow-data contract fixtures at a
# stable path the pytest reads via WORKFLOW_DATA_CONTRACT_FIXTURE_DIR. The registry
# `extraSync` re-stages live fixture edits into /app/.contract-fixtures so the
# in-pod `/__run?cmd=contract` lane re-checks them.
COPY services/shared/workflow-data-contract /app/.contract-fixtures
ENV WORKFLOW_DATA_CONTRACT_FIXTURE_DIR=/app/.contract-fixtures/fixtures

# Baseline capture-only build inputs in the same hidden paths used by sync.sh.
# Receiver diff receipts can then distinguish unchanged transport files from edits.
COPY services/workflow-orchestrator/Dockerfile /app/.preview-capture/production.Dockerfile
COPY skaffold/dev/workflow-orchestrator/Dockerfile.dev /app/.preview-capture/development.Dockerfile

# #40 exec bridge: /__run commands execute HERE (python/pytest live in this
# container; the node-only dev-sync-sidecar exits 127 on them). Lives OUTSIDE
# /app so the shared emptyDir workdir mount can never mask it. Background child
# of the entrypoint; binds 127.0.0.1 only, fails closed without
# DEV_SYNC_COMMANDS_JSON (plain `skaffold dev` unaffected).
COPY services/dev-sync-sidecar/exec_bridge.py /devtools/exec_bridge.py

RUN groupadd --gid 1001 dev-runtime \
    && useradd --uid 1001 --gid dev-runtime --create-home dev-runtime \
    && chown -R 1001:1001 /app /devtools

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PORT=8080 \
    HOST=0.0.0.0 \
    MIN_DAPR_RUNTIME_VERSION=1.17.0 \
    ENFORCE_MIN_DAPR_VERSION=false

ENV PATH=/app/.venv/bin:$PATH

EXPOSE 8080

USER 1001:1001

# `uvicorn --reload --reload-dir /app` watches the filesystem and restarts on
# .py changes. Skaffold sync drops new files in /app; uvicorn picks them up.
# The exec bridge is a background child; `exec` keeps uvicorn as PID 1 (a
# bridge crash never takes the dev server down, and vice versa).
CMD ["sh", "-c", "python /devtools/exec_bridge.py & exec python -m uvicorn app:app --host 0.0.0.0 --port 8080 --reload --reload-dir /app"]
